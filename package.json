{
  "name": "flex-headers",
  "version": "1.9.5",
  "private": true,
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3"
  },
  "scripts": {
    "postinstall": "wxt prepare",
    "start": "wxt",
    "start:firefox": "wxt -b firefox --mv3",
    "dev:web": "vite --config vite.web.config.ts",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "build": "bun run build:chrome && bun run build:firefox",
    "package": "node scripts/build-and-package.mjs",
    "release": "node scripts/ensure-version-bumped.mjs && node scripts/build-and-package.mjs",
    "test": "vitest run",
    "test:update-fixtures": "UPDATE_FIXTURES=true vitest run src/background/background.test.ts",
    "test:e2e:install": "playwright install chromium",
    "pretest:e2e": "bun run build:chrome",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}